# ============================================================
#  Dr. Nisha — Medical AI Chatbot  |  Environment Variables
# ============================================================

# -----------------------------------------------------------
# 1. GEMINI API KEY  (REQUIRED)
#    Get your free key from: https://aistudio.google.com/apikey
# -----------------------------------------------------------
GEMINI_API_KEY=your_google_gemini_api_key_here

# -----------------------------------------------------------
# 2. DATABASE URL  (REQUIRED)
#    PostgreSQL connection string for storing conversations.
#    Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
#    Example (Hostinger / any VPS PostgreSQL):
# -----------------------------------------------------------
DATABASE_URL=postgres://db_user:db_password@localhost:5432/dr_nisha

# -----------------------------------------------------------
# 3. SERVER PORT  (OPTIONAL — default: 3000)
#    The port on which the server will listen.
# -----------------------------------------------------------
PORT=3000

# -----------------------------------------------------------
# 4. NODE ENVIRONMENT  (REQUIRED — must be "production")
# -----------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------
# 5. SESSION SECRET  (RECOMMENDED)
#    A long random string used for session security.
#    You can generate one at: https://generate-secret.vercel.app/32
# -----------------------------------------------------------
SESSION_SECRET=change_this_to_a_long_random_secret_string
